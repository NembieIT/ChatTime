{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ChatTime",
  "version": "1.0.0",
  "identifier": "com.chattime.app",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd client && npm run build",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "ChatTime",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 480,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
